{
  "manifest_version": 3,
  "name": "Marked'X Down",
  "version": "1.0",
  "description": "Parses and displays Markdown and LaTeX in X.com tweets while preserving native SPA links and styles.",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["katex.min.js", "marked.min.js", "content.js"],
      "css": ["katex.min.css", "style.css"],
      "run_at": "document_idle"
    }
  ]
}
